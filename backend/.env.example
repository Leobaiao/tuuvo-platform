# Postgres
DATABASE_URL=postgres://tuuvo:tuuvo@postgres:5432/tuuvo

# Auth
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=8h

# Criptografia de credenciais de canal (32 bytes em base64)
CREDENTIALS_ENCRYPTION_KEY=troque-por-uma-chave-de-32-bytes-em-base64

# WhatsApp — driver GTI (por instância, token vem do banco por tenant)
GTI_BASE_URL=https://api.gtiapi.workers.dev

# SMS/RCS — broker MKOM (credenciais reais ficam em platform_channel_providers)
MKOM_SMS_BASE_URL=https://sms.mkmservice.com/sms/api/transmission/v1

# URL pública do backend, usada para registrar webhooks nos brokers
PUBLIC_BASE_URL=https://api.tuuvo.app.br

PORT=3000
