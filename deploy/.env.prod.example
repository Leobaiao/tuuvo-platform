# ═══════════════════════════════════════════════════
# TUUVO — Variáveis de Produção
# Este arquivo é gerado automaticamente pelo GitHub Actions.
# NÃO commitar valores reais — usar Secrets no GitHub.
# ═══════════════════════════════════════════════════

# ─── Postgres ───
POSTGRES_USER=tuuvo
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=tuuvo

# ─── Auth ───
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=8h

# ─── Criptografia de credenciais de canal (32 bytes em base64) ───
CREDENTIALS_ENCRYPTION_KEY=CHANGE_ME

# ─── WhatsApp — driver GTI ───
GTI_BASE_URL=https://api.gtiapi.workers.dev

# ─── SMS/RCS — broker MKOM ───
MKOM_SMS_BASE_URL=https://sms.mkmservice.com/sms/api/transmission/v1

# ─── URL pública do backend (usada para registrar webhooks) ───
PUBLIC_BASE_URL=https://api.tuuvo.app.br

# ─── Porta interna do container (NÃO mudar sem ajustar docker-compose) ───
PORT=3000
